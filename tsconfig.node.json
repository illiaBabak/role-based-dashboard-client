{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": ["vite.config.ts", "cypress.config.ts"],
  "exclude": ["node_modules"]
}
